{
	"name": "@yofriadi/pi-provider-antigravity",
	"version": "0.2.0",
	"publishConfig": {
		"access": "public"
	},
	"type": "module",
	"description": "Pi extension that restores the Antigravity (Gemini 3, Claude, GPT-OSS) OAuth provider.",
	"license": "MIT",
	"author": {
		"name": "Yofriadi Yahya",
		"email": "yofriadi.yahya@proton.me"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/yofriadi/pi-extensions.git",
		"directory": "packages/pi-provider-antigravity"
	},
	"bugs": {
		"url": "https://github.com/yofriadi/pi-extensions/issues"
	},
	"homepage": "https://github.com/yofriadi/pi-extensions#readme",
	"keywords": [
		"pi-package",
		"pi-extension",
		"google",
		"gemini",
		"antigravity",
		"claude",
		"oauth"
	],
	"engines": {
		"node": ">=22.19.0"
	},
	"files": [
		"scripts/**/*",
		"src/**/*"
	],
