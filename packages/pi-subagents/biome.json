{
  "root": false,
  "$schema": "https://biomejs.dev/schemas/2.4.16/schema.json",
  "extends": "//",
  "formatter": {
    "enabled": false
  },
  "linter": {
    "rules": {
      "style": {
        "recommended": false
      },
      "suspicious": {
        "noExplicitAny": "off",
        "noControlCharactersInRegex": "off",
        "noEmptyInterface": "off"
      }
    }
  },
  "files": {
    "includes": ["src/**/*.ts", "test/**/*.ts"]
  }
}
